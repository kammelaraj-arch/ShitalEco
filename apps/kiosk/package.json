{
  "name": "@shital/kiosk",
  "version": "1.0.0",
  "private": true,
  "description": "Shital Temple Self-Service Kiosk — McDonald's quality touch interface",
  "main": "src/main/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build && electron-builder",
    "preview": "vite preview"
  },
  "dependencies": {
    "framer-motion": "^11.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "zustand": "^4.5.0",
    "qrcode.react": "^3.1.0",
    "@stripe/react-stripe-js": "^2.7.0",
    "@stripe/stripe-js": "^4.1.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0",
    "vite": "^5.3.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "org.shital.kiosk",
    "productName": "Shital Kiosk",
    "win": { "target": "nsis" },
    "linux": { "target": "deb" },
    "kiosk": true
  }
}
